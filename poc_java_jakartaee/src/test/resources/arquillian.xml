<?xml version="1.0" encoding="UTF-8"?>
<arquillian xmlns="http://jboss.org/schema/arquillian"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://jboss.org/schema/arquillian
                http://jboss.org/schema/arquillian/arquillian_1_0.xsd">

    <!--
        Payara Embedded container — Arquillian will:
        1. Boot an embedded Payara inside the test JVM (no external installation needed)
        2. Deploy the test archive
        3. Run the tests
        4. Undeploy and shut down

        This is the Jakarta EE equivalent of Spring Boot's @SpringBootTest:
        full container with CDI, EJB, JPA, DataSources, JNDI, etc.
        No local Payara installation required — the runtime comes from Maven.
    -->
    <container qualifier="payara-embedded" default="true">
        <configuration>
            <!-- Cleanup temporary files after tests -->
            <property name="cleanup">true</property>
        </configuration>
    </container>

</arquillian>

